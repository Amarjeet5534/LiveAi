# ================================================
# LiveAI Assistant - Environment Configuration
# Copy this file to .env and customize values
# ================================================

# ================================================
# SERVER CONFIGURATION
# ================================================
HOST=0.0.0.0
PORT=8000
DEBUG=False
WORKERS=4

# ================================================
# DATABASE CONFIGURATION
# ================================================
# For local development:
DATABASE_URL=sqlite:///liveai.db
DB_FILE=liveai.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/liveai_db

# ================================================
# LLM & OLLAMA CONFIGURATION
# ================================================
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=phi3
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=100

# ================================================
# VOICE CONFIGURATION
# ================================================
VOICE_DEVICE=18
RECORDING_DURATION=5
WHISPER_MODEL=tiny.en
TEXT_TO_SPEECH_VOICE=en-US-GuyNeural

# ================================================
# SECURITY & AUTHENTICATION
# ================================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
SESSION_TIMEOUT_HOURS=24
JWT_ALGORITHM=HS256

# ================================================
# FEATURE FLAGS
# ================================================
ENABLE_VOICE=True
ENABLE_FILE_UPLOAD=False
ENABLE_ADMIN_PANEL=True
ENABLE_ANALYTICS=True
STRICT_MODE=True

# ================================================
# FILE UPLOAD CONFIGURATION
# ================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=txt,pdf,csv,json

# ================================================
# LOGGING CONFIGURATION
# ================================================
LOG_LEVEL=INFO
LOG_FILE=liveai.log
LOG_FORMAT=json

# ================================================
# SAFETY & RESTRICTIONS
# ================================================
# Comma-separated list of blocked command patterns
BLOCKED_COMMANDS=rm -rf,format,shutdown,taskkill,pkill

# Comma-separated list of allowed command keywords
ALLOWED_KEYWORDS=open,search,click,scroll,type,screenshot,read

# ================================================
# RATE LIMITING
# ================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ================================================
# CORS CONFIGURATION
# ================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ================================================
# EMAIL CONFIGURATION (for notifications)
# ================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@liveai.ai

# ================================================
# MONITORING & ANALYTICS
# ================================================
SENTRY_DSN=  # Error tracking (optional)
PROMETHEUS_ENABLED=False

# ================================================
# DEPLOYMENT ENVIRONMENT
# ================================================
ENVIRONMENT=development
# Options: development, staging, production

# ================================================
# DOCKER CONFIGURATION
# ================================================
# Only used in Docker containers:
CONTAINER_PORT=8000
WORKERS_COUNT=4
